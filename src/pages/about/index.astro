---
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: 'Hobbies' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings} comment>
  <p>Embedded Software Developer</p>
  <p>
    I'm Akatsuki. I working as an embedded software developer and develop Open-source flight controller. I majored in Computer Science and Technology and graduated in 2026. 
    My interest was Industrial Internet of Things (IIoT), and my research focused on physical layer key generation (PLKG).
    I also interest in Metalcore, Electronicore and Japanese Loud Rock music genre.
  </p>
  <p>
    Motto: We all get used to in the end, whatever goes. 
    <!-- <Spoiler>sxunさん我想你了</Spoiler> -->
  </p>

  {/* tools */}
  <h2 id='tools'>Tools</h2>
  <p>Current support tools as follow:</p>
  <ToolSection
